NODE_ENV=development
PORT=4000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=rental_crm
DB_POOL_SIZE=10

# Session/cookie security
SESSION_COOKIE_NAME=portal.sid
SESSION_SECRET=replace_with_long_random_secret_min_32_chars
SESSION_TTL_MS=43200000
TRUST_PROXY=0
REQUIRE_HTTPS_IN_PROD=true

# Redis session store (required in production)
REDIS_URL=
REDIS_PREFIX=sess:rental:

# CORS allowlist (comma-separated). Required in production.
# Example: http://localhost:3000,https://portal.example.com
CORS_ALLOWED_ORIGINS=http://localhost:4000,http://localhost:3000

# Brute-force protection
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
LOGIN_FAILURE_RATE_LIMIT_MAX=5
SESSION_RATE_LIMIT_WINDOW_MS=60000
SESSION_RATE_LIMIT_MAX=120

# Explicitly allow local fallback credentials only in development
ENABLE_DEV_AUTH_FALLBACK=false

# Required in production (bcrypt hash preferred, scrypt legacy supported)
APITCHENKOV_ADMIN_USERNAME=
APITCHENKOV_ADMIN_PASSWORD_HASH=
CINETOOLS_ADMIN_USERNAME=
CINETOOLS_ADMIN_PASSWORD_HASH=
PORTAL_ADMIN_USERNAME=
PORTAL_ADMIN_PASSWORD_HASH=

# Optional PDF font overrides
# PDF_FONT_REGULAR=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
# PDF_FONT_BOLD=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf

# Optional: serve CineTools static pages from external folder
# CINETOOLS_WEB_ROOT=/var/www/cinetools
